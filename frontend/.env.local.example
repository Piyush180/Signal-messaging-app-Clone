# Copy to `.env.local`. These are baked into the browser bundle at build time,
# so they must be PUBLIC (no secrets here). NEXT_PUBLIC_ prefix is required for
# a variable to be readable in the browser.

# Where the FastAPI backend lives. No trailing slash.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# WebSocket origin. Usually the same host as the API with ws:// (or wss:// in
# production). If omitted, the app derives it from NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
