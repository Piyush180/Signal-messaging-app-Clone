# Copy to `.env` and adjust for your environment.
# Real deployments MUST override SECRET_KEY with a strong random value.

PROJECT_NAME="Signal Clone API"
ENVIRONMENT="development"

# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY="dev-only-insecure-key-change-me-in-production"

ACCESS_TOKEN_EXPIRE_MINUTES=10080
MOCK_OTP_CODE="123456"

DATABASE_URL="sqlite+aiosqlite:///./signal.db"

# Comma-separated browser origins allowed to call the API (no trailing slash).
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

AUTO_INIT_DB=true
